# Crypto-Panda Environment Variables
# Copy this file to .env and fill in your values

# === API Keys (required) ===
COIN_PAPRIKA_API_KEY=           # CoinPaprika API key (https://coinpaprika.com/api/)
CRYPTO_NEWS_API_KEY=            # CryptoNews API key (https://cryptonews-api.com/)
OPENAI_API_KEY=                 # OpenAI API key for GPT-4o recommendations

# === Email / SMTP (required for report delivery) ===
EMAIL_FROM=                     # Sender email address
EMAIL_TO=                       # Recipient email address (comma-separated for multiple)
SMTP_SERVER=                    # SMTP server (e.g., smtp.gmail.com)
SMTP_USERNAME=                  # SMTP login username
SMTP_PASSWORD=                  # SMTP login password (use app password for Gmail)

# === Aurora PostgreSQL (required for historical tracking) ===
AURORA_HOST=                    # Database host endpoint
AURORA_PORT=5432                # Database port (default: 5432)
AURORA_DB=                      # Database name
AURORA_USER=                    # Database username
AURORA_PASSWORD=                # Database password

# === Optional ===
LOG_LEVEL=INFO                  # Logging level (DEBUG, INFO, WARNING, ERROR)
